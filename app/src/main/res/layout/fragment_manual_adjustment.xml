<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Status Section -->
        <TextView
            android:id="@+id/text_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Manual Model Adjustment"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@android:color/black"
            android:gravity="center"
            android:layout_marginBottom="16dp" />

        <TextView
            android:id="@+id/text_model_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="No model loaded"
            android:textSize="14sp"
            android:textColor="@android:color/darker_gray"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/text_landmark_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Load a model first"
            android:textSize="14sp"
            android:textColor="@android:color/darker_gray"
            android:layout_marginBottom="16dp" />

        <!-- Scale Controls -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📏 Scale Controls"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@android:color/black"
            android:layout_marginBottom="8dp" />

        <!-- Uniform Scale -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="80dp"
                android:layout_height="wrap_content"
                android:text="Scale:"
                android:textColor="@android:color/black" />

            <SeekBar
                android:id="@+id/seek_bar_scale"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:max="100"
                android:progress="50" />

            <TextView
                android:id="@+id/text_scale_value"
                android:layout_width="60dp"
                android:layout_height="wrap_content"
                android:text="1.00"
                android:textColor="@android:color/black"
                android:gravity="end" />
        </LinearLayout>

        <!-- Scale X (Horizontal) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="80dp"
                android:layout_height="wrap_content"
                android:text="Width:"
                android:textColor="@android:color/black" />

            <SeekBar
                android:id="@+id/seek_bar_scale_x"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:max="100"
                android:progress="33" />

            <TextView
                android:id="@+id/text_scale_x_value"
                android:layout_width="60dp"
                android:layout_height="wrap_content"
                android:text="1.00"
                android:textColor="@android:color/black"
                android:gravity="end" />
        </LinearLayout>

        <!-- Scale Y (Vertical) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="80dp"
                android:layout_height="wrap_content"
                android:text="Height:"
                android:textColor="@android:color/black" />

            <SeekBar
                android:id="@+id/seek_bar_scale_y"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:max="100"
                android:progress="33" />

            <TextView
                android:id="@+id/text_scale_y_value"
                android:layout_width="60dp"
                android:layout_height="wrap_content"
                android:text="1.00"
                android:textColor="@android:color/black"
                android:gravity="end" />
        </LinearLayout>

        <!-- Position Controls -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📍 Position Controls"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@android:color/black"
            android:layout_marginBottom="8dp" />

        <!-- Offset X -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="80dp"
                android:layout_height="wrap_content"
                android:text="X Offset:"
                android:textColor="@android:color/black" />

            <SeekBar
                android:id="@+id/seek_bar_offset_x"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:max="100"
                android:progress="50" />

            <TextView
                android:id="@+id/text_offset_x_value"
                android:layout_width="60dp"
                android:layout_height="wrap_content"
                android:text="0.000"
                android:textColor="@android:color/black"
                android:gravity="end" />
        </LinearLayout>

        <!-- Offset Y -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="80dp"
                android:layout_height="wrap_content"
                android:text="Y Offset:"
                android:textColor="@android:color/black" />

            <SeekBar
                android:id="@+id/seek_bar_offset_y"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:max="100"
                android:progress="50" />

            <TextView
                android:id="@+id/text_offset_y_value"
                android:layout_width="60dp"
                android:layout_height="wrap_content"
                android:text="0.000"
                android:textColor="@android:color/black"
                android:gravity="end" />
        </LinearLayout>

        <!-- Offset Z -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="80dp"
                android:layout_height="wrap_content"
                android:text="Z Offset:"
                android:textColor="@android:color/black" />

            <SeekBar
                android:id="@+id/seek_bar_offset_z"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:max="100"
                android:progress="50" />

            <TextView
                android:id="@+id/text_offset_z_value"
                android:layout_width="60dp"
                android:layout_height="wrap_content"
                android:text="0.000"
                android:textColor="@android:color/black"
                android:gravity="end" />
        </LinearLayout>

        <!-- Rotation Controls -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🔄 Rotation Controls"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@android:color/black"
            android:layout_marginBottom="8dp" />

        <!-- Rotation X (Pitch) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="80dp"
                android:layout_height="wrap_content"
                android:text="Pitch:"
                android:textColor="@android:color/black" />

            <SeekBar
                android:id="@+id/seek_bar_rotation_x"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:max="360"
                android:progress="180" />

            <TextView
                android:id="@+id/text_rotation_x_value"
                android:layout_width="60dp"
                android:layout_height="wrap_content"
                android:text="0.0°"
                android:textColor="@android:color/black"
                android:gravity="end" />
        </LinearLayout>

        <!-- Rotation Y (Yaw) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="80dp"
                android:layout_height="wrap_content"
                android:text="Yaw:"
                android:textColor="@android:color/black" />

            <SeekBar
                android:id="@+id/seek_bar_rotation_y"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:max="360"
                android:progress="180" />

            <TextView
                android:id="@+id/text_rotation_y_value"
                android:layout_width="60dp"
                android:layout_height="wrap_content"
                android:text="0.0°"
                android:textColor="@android:color/black"
                android:gravity="end" />
        </LinearLayout>

        <!-- Rotation Z (Roll) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="80dp"
                android:layout_height="wrap_content"
                android:text="Roll:"
                android:textColor="@android:color/black" />

            <SeekBar
                android:id="@+id/seek_bar_rotation_z"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:max="360"
                android:progress="180" />

            <TextView
                android:id="@+id/text_rotation_z_value"
                android:layout_width="60dp"
                android:layout_height="wrap_content"
                android:text="0.0°"
                android:textColor="@android:color/black"
                android:gravity="end" />
        </LinearLayout>

        <!-- Landmark Detection Controls -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🎯 Landmark Detection"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@android:color/black"
            android:layout_marginBottom="8dp" />

        <!-- Landmark Detection Toggle -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Enable Landmark Detection"
                android:textColor="@android:color/black" />

            <Switch
                android:id="@+id/switch_landmark_detection"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true" />
        </LinearLayout>

        <!-- Confidence Threshold -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="80dp"
                android:layout_height="wrap_content"
                android:text="Confidence:"
                android:textColor="@android:color/black" />

            <SeekBar
                android:id="@+id/seek_bar_landmark_confidence"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:max="100"
                android:progress="50" />

            <TextView
                android:id="@+id/text_landmark_confidence_value"
                android:layout_width="60dp"
                android:layout_height="wrap_content"
                android:text="0.50"
                android:textColor="@android:color/black"
                android:gravity="end" />
        </LinearLayout>

        <!-- Action Buttons -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⚙️ Actions"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@android:color/black"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="16dp">

            <Button
                android:id="@+id/button_detect_landmarks"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🔍 Detect Landmarks"
                android:layout_marginBottom="8dp" />

            <Button
                android:id="@+id/button_apply_to_model"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="✅ Apply to Model"
                android:layout_marginBottom="8dp" />

            <Button
                android:id="@+id/button_save_landmark_data"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="💾 Save Landmark Data"
                android:layout_marginBottom="8dp" />

            <Button
                android:id="@+id/button_reset_adjustments"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🔄 Reset to Defaults"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton" />
        </LinearLayout>

        <!-- Progress Bar -->
        <ProgressBar
            android:id="@+id/progress_bar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone"
            style="?android:attr/progressBarStyleHorizontal"
            android:indeterminate="true" />

    </LinearLayout>
</ScrollView>