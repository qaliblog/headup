<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/permissions_fragment">

    <fragment
        android:id="@+id/permissions_fragment"
        android:name="com.qali.headup.fragment.PermissionsFragment"
        android:label="PermissionsFragment">

        <action
            android:id="@+id/action_permissions_to_camera"
            app:destination="@id/camera_fragment"
            app:popUpTo="@id/permissions_fragment"
            app:popUpToInclusive="true" />

    </fragment>

    <fragment
        android:id="@+id/camera_fragment"
        android:name="com.qali.headup.fragment.CameraFragment"
        android:label="CameraFragment">

        <action
            android:id="@+id/action_camera_to_permissions"
            app:destination="@id/permissions_fragment"
            app:popUpTo="@id/camera_fragment"
            app:popUpToInclusive="true" />
            
        <action
            android:id="@+id/action_camera_to_model3d"
            app:destination="@id/model3d_fragment" />
    </fragment>

    <fragment
        android:id="@+id/gallery_fragment"
        android:name="com.qali.headup.fragment.GalleryFragment"
        android:label="GalleryFragment" />
        
    <fragment
        android:id="@+id/model3d_fragment"
        android:name="com.qali.headup.fragment.Model3DFragment"
        android:label="Model3DFragment">
        
        <action
            android:id="@+id/action_model3d_to_camera"
            app:destination="@id/camera_fragment" />
            
        <action
            android:id="@+id/action_model3d_to_library"
            app:destination="@id/model_library_fragment" />
    </fragment>
    
    <fragment
        android:id="@+id/model_library_fragment"
        android:name="com.qali.headup.fragment.ModelLibraryFragment"
        android:label="ModelLibraryFragment">
        
        <action
            android:id="@+id/action_library_to_camera"
            app:destination="@id/camera_fragment" />
            
        <action
            android:id="@+id/action_library_to_model3d"
            app:destination="@id/model3d_fragment" />
            
        <action
            android:id="@+id/action_library_to_preview"
            app:destination="@id/model_preview_fragment" />
    </fragment>
    
    <fragment
        android:id="@+id/model_preview_fragment"
        android:name="com.qali.headup.fragment.ModelPreviewFragment"
        android:label="ModelPreviewFragment">
        
        <action
            android:id="@+id/action_preview_to_camera"
            app:destination="@id/camera_fragment" />
            
        <action
            android:id="@+id/action_preview_to_library"
            app:destination="@id/model_library_fragment" />
            
        <action
            android:id="@+id/action_preview_to_manual_adjustment"
            app:destination="@id/manual_adjustment_fragment" />
    </fragment>

    <fragment
        android:id="@+id/manual_adjustment_fragment"
        android:name="com.qali.headup.fragment.ManualAdjustmentFragment"
        android:label="ManualAdjustmentFragment">

        <action
            android:id="@+id/action_manual_adjustment_to_camera"
            app:destination="@id/camera_fragment" />

        <action
            android:id="@+id/action_manual_adjustment_to_model3d"
            app:destination="@id/model3d_fragment" />

        <action
            android:id="@+id/action_manual_adjustment_to_library"
            app:destination="@id/model_library_fragment" />

        <action
            android:id="@+id/action_manual_adjustment_to_preview"
            app:destination="@id/model_preview_fragment" />

    </fragment>
</navigation>
